{
  "name": "@stockflow/api-core",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "lint": "eslint . --fix",
    "format": "prettier --write src",
    "type-check": "tsc --noEmit",
    "build": "tsc",
    "dev": "nodemon",
    "start": "tsx src/server.ts",
    "db:migrate": "prisma migrate dev",
    "db:generate": "prisma generate",
    "db:status": "prisma migrate status",
    "db:reset": "prisma migrate reset --force",
    "db:studio": "prisma studio"
  },
  "packageManager": "pnpm@10.32.1",
  "devDependencies": {
    "@stockflow/eslint-config": "workspace:*",
    "@stockflow/prettier-config": "workspace:*",
    "@types/express": "^5.0.6",
    "@types/morgan": "^1.9.10",
    "@types/node": "^24.12.3",
    "dotenv": "^17.4.2",
    "nodemon": "^3.1.14",
    "prisma": "^7.8.0",
    "tsx": "^4.21.0"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "cross-env": "^10.1.0",
    "express": "^5.2.1",
    "morgan": "^1.10.1",
    "zod": "^4.4.3"
  }
}